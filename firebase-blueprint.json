{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores teacher profile and preferences.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "schoolName": { "type": "string" },
        "preferredGrade": { "type": "string" },
        "preferredSubject": { "type": "string" },
        "teachingModel": { "type": "string", "enum": ["5E", "Competency-based", "Inquiry-based", "Direct instruction"] },
        "lessonDetail": { "type": "string", "enum": ["Short", "Standard", "Detailed", "Observation-Ready"] },
        "curriculumStructure": { "type": "string", "enum": ["Terms", "Cycles"] }
      },
      "required": ["name", "email"]
    },
    "CurriculumEntry": {
      "title": "Curriculum Entry",
      "description": "A structured learning outcome extracted from a curriculum guide.",
      "type": "object",
      "properties": {
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "strand": { "type": "string" },
        "cycle": { "type": "number" },
        "topic": { "type": "string" },
        "subtopic": { "type": "string" },
        "learning_outcomes": { "type": "array", "items": { "type": "string" } },
        "assessment_suggestions": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["grade", "subject", "topic", "learning_outcomes", "createdBy"]
    },
    "CurriculumUnit": {
      "title": "Curriculum Unit",
      "description": "A structured unit from a teacher's guide.",
      "type": "object",
      "properties": {
        "unitNumber": { "type": "string" },
        "unitTitle": { "type": "string" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "outcomes": { "type": "array", "items": { "type": "string" } },
        "competencies": { "type": "array", "items": { "type": "string" } },
        "timeAllocation": { "type": "string" },
        "weeklyBreakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "week": { "type": "number" },
              "focus": { "type": "string" },
              "activities": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "readingFocus": { "type": "string" },
        "speakingListeningFocus": { "type": "string" },
        "languageFocus": { "type": "string" },
        "wordWorkFocus": { "type": "string" },
        "writingFocus": { "type": "string" },
        "studentBookPages": { "type": "string" },
        "workbookPages": { "type": "string" },
        "teachingNotes": { "type": "string" },
        "supportSuggestions": { "type": "string" },
        "extensionSuggestions": { "type": "string" },
        "additionalSkillsPractice": { "type": "string" },
        "answersGuidance": { "type": "string" },
        "source": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["unitNumber", "unitTitle", "grade", "subject", "outcomes", "createdBy"]
    },
    "LessonPlan": {
      "title": "Lesson Plan",
      "description": "A generated lesson plan.",
      "type": "object",
      "properties": {
        "lessonTitle": { "type": "string" },
        "studentTeacherName": { "type": "string" },
        "date": { "type": "string" },
        "classSize": { "type": "string" },
        "ageRange": { "type": "string" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "cycle": { "type": "number" },
        "week": { "type": "number" },
        "topic": { "type": "string" },
        "subtopic": { "type": "string" },
        "duration": { "type": "string" },
        "teachingModel": { "type": "string" },
        "learning_outcomes": { "type": "array", "items": { "type": "string" } },
        "previousKnowledge": { "type": "string" },
        "generalObjective": { "type": "string" },
        "specificObjectives": { "type": "array", "items": { "type": "string" } },
        "keyVocabulary": { "type": "array", "items": { "type": "string" } },
        "materials": { "type": "array", "items": { "type": "string" } },
        "setInduction": { "type": "string" },
        "developmentSteps": { "type": "string" },
        "guidedPractice": { "type": "string" },
        "independentPractice": { "type": "string" },
        "differentiation": { "type": "string" },
        "assessment": { "type": "string" },
        "closure": { "type": "string" },
        "homework": { "type": "string" },
        "reflection": { "type": "string" },
        "teacherScript": { "type": "string" },
        "status": { "type": "string", "enum": ["Not Started", "Planned", "Taught", "Completed", "Skipped", "Postponed", "Needs Review", "Partially Taught"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["lessonTitle", "grade", "subject", "topic", "generalObjective", "specificObjectives", "createdBy"]
    },
    "WeeklyPlan": {
      "title": "Weekly Plan",
      "description": "A curriculum map for a cycle.",
      "type": "object",
      "properties": {
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "cycle": { "type": "number" },
        "weeks": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "week": { "type": "number" },
              "focus": { "type": "string" },
              "topics": { "type": "array", "items": { "type": "string" } },
              "learning_outcomes": { "type": "array", "items": { "type": "string" } },
              "lesson_count": { "type": "number" },
              "assessment_type": { "type": "string" },
              "review_suggestion": { "type": "string" },
              "teaching_notes": { "type": "string" }
            }
          } 
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["grade", "subject", "cycle", "weeks", "createdBy"]
    },
    "WeeklyCurriculumPlan": {
      "title": "Weekly Curriculum Plan",
      "description": "A detailed curriculum-driven plan for a specific week.",
      "type": "object",
      "properties": {
        "grade_level": { "type": "string" },
        "subject": { "type": "string" },
        "cycle": { "type": "number" },
        "week_number": { "type": "number" },
        "weekly_topic": { "type": "string" },
        "weekly_subtopics": { "type": "array", "items": { "type": "string" } },
        "weekly_learning_outcomes": { "type": "array", "items": { "type": "string" } },
        "number_of_days": { "type": "number" },
        "daily_lesson_titles": { "type": "array", "items": { "type": "string" } },
        "daily_objectives": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
        "suggested_assessment": { "type": "string" },
        "teacher_notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["grade_level", "subject", "cycle", "week_number", "weekly_topic", "weekly_learning_outcomes", "number_of_days", "createdBy"]
    },
    "DailyLessonPlan": {
      "title": "Daily Lesson Plan",
      "description": "A specific lesson plan for a single day, linked to a weekly plan.",
      "type": "object",
      "properties": {
        "weekly_plan_id": { "type": "string" },
        "day_number": { "type": "number" },
        "lesson_title": { "type": "string" },
        "topic": { "type": "string" },
        "subtopic": { "type": "string" },
        "learning_outcome": { "type": "string" },
        "specific_daily_objectives": { "type": "array", "items": { "type": "string" } },
        "generated_lesson_content": { "type": "string" },
        "structured_json": { "type": "object" },
        "status": { "type": "string", "enum": ["Not Started", "Planned", "Taught", "Completed", "Skipped", "Postponed", "Needs Review", "Partially Taught"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weekly_plan_id", "day_number", "lesson_title", "topic", "createdBy"]
    },
    "Resource": {
      "title": "Resource",
      "description": "A generated teaching resource.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "resource_type": { "type": "string" },
        "grade_level": { "type": "string" },
        "subject": { "type": "string" },
        "cycle": { "type": "number" },
        "week": { "type": "number" },
        "topic": { "type": "string" },
        "subtopic": { "type": "string" },
        "learning_outcome": { "type": "string" },
        "generated_content": { "type": "string" },
        "status": { "type": "string", "enum": ["Not Generated", "Generated", "Edited", "Printed", "Downloaded", "Needs Review", "Archived"] },
        "lessonId": { "type": "string" },
        "isFavorite": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "resource_type", "grade_level", "subject", "cycle", "topic", "generated_content", "createdBy"]
    },
    "TeachingCollection": {
      "title": "Teaching Collection",
      "description": "A custom folder or collection of teaching materials.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "itemIds": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["lesson", "resource", "plan"] },
              "id": { "type": "string" }
            }
          } 
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "itemIds", "createdBy"]
    },
    "WeeklyAcademicPlan": {
      "title": "Weekly Academic Plan",
      "description": "A teaching plan for a specific week.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cycle_number": { "type": "number" },
        "week_number": { "type": "number" },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "lessons": { "type": "array", "items": { "type": "object" } },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["empty", "planned", "completed"] },
        "grade": { "type": "string" },
        "subject": { "type": "string" }
      },
      "required": ["userId", "cycle_number", "week_number", "start_date", "end_date"]
    },
    "FavoriteItem": {
      "title": "Favorite Item",
      "description": "A starred or favorited item.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["lesson", "resource", "plan", "cycle-plan"] },
        "itemId": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "itemId", "createdBy"]
    },
    "VersionRecord": {
      "title": "Version Record",
