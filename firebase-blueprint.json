        "itemId": { "type": "string" },
        "itemType": { "type": "string", "enum": ["lesson", "resource", "plan"] },
        "versionNumber": { "type": "number" },
        "content": { "type": "object" },
        "note": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "itemType", "versionNumber", "content", "createdBy"]
    },
    "SavedLesson": {
      "title": "Saved Lesson",
      "description": "A structured lesson object for delivery.",
      "type": "object",
      "properties": {
        "lesson_plan_id": { "type": "string" },
        "class_id": { "type": "string" },
        "createdBy": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "sub_topic": { "type": "string" },
        "cycle": { "type": "string" },
        "week": { "type": "string" },
        "duration": { "type": "string" },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "learning_outcomes": { "type": "array", "items": { "type": "string" } },
        "key_vocabulary": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "ready", "taught", "completed"] },
        "last_opened": { "type": "string", "format": "date-time" },
        "completion_status": { "type": "object" }
      },
      "required": ["lesson_plan_id", "class_id", "createdBy", "title", "subject", "topic", "status", "last_opened"]
    },
    "LessonResourceNew": {
      "title": "Lesson Resource New",
